# Local runtime
.venv/
__pycache__/
*.py[cod]
*$py.class

# OS/editor noise
.DS_Store
.idea/
.vscode/

# Secrets and machine-local Codex config
.env
.env.*
.codex/

# Test/build caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
dist/
build/
*.egg-info/

# Generated investment data; keep only directory placeholders in git
data/cache/**
data/raw/**
data/normalized/**
data/reports/**
!data/cache/.gitkeep
!data/raw/.gitkeep
!data/normalized/.gitkeep
!data/reports/.gitkeep

# Personal portfolio context; keep templates in git instead.
companies/portfolio_profile.yaml
companies/holdings.yaml
companies/watchlist.yaml
companies/thesis_tracker.yaml
memos/*portfolio_context*.md
!memos/portfolio_context.example.md
